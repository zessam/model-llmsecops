# OpenTofu
# NOTE: .terraform.lock.hcl IS committed on purpose (reproducible provider
# versions). It now records registry.opentofu.org hashes, not registry.terraform.io.
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!terraform.tfvars.example
tfplan
tfplan.*
crash.log
.env
.claude
# Python (security probe scripts)
__pycache__/
*.pyc

# promptfoo auth token (contains a credential) and scan output
security/promptfoo/.pfhome/
security/promptfoo/results.json
